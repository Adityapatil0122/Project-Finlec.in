generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  INVESTOR
  ADVISOR
  ADMIN
}

enum RiskProfile {
  LOW
  MODERATE
  HIGH
}

enum PortfolioStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum TransactionType {
  BUY
  SELL
  SWITCH
  REDEEM
  STP
  SWP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SIPFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SIPStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum KYCDocumentType {
  PAN
  AADHAAR
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  OTHER
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum ContactInquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvestorResidencyStatus {
  RESIDENT_INDIAN
  NRI
}

enum TaxStatus {
  INDIVIDUAL
  HUF
  MINOR
}

enum InvestorOnboardingStatus {
  DRAFT
  IN_PROGRESS
  REVIEW_REQUIRED
  READY_TO_INVEST
  ACTIVE
}

enum KycCaseStatus {
  NOT_STARTED
  REGISTERED
  VALIDATED
  ON_HOLD
  REJECTED
}

enum BankAccountStatus {
  PENDING
  VERIFIED
  FAILED
}

enum PaymentRail {
  UPI
  UPI_AUTOPAY
  ENACH
  NACH
  NETBANKING
}

enum BankMandateStatus {
  PENDING
  ACTIVE
  PAUSED
  REVOKED
  FAILED
}

enum NominationStatus {
  PENDING
  ACTIVE
  DECLINED
}

enum HolderMode {
  SINGLE
  JOINT
}

enum OrderKind {
  LUMPSUM_PURCHASE
  ADDITIONAL_PURCHASE
  REDEMPTION
  SWITCH
  SIP_REGISTRATION
  SIP_PAUSE
  SIP_RESUME
  SIP_CANCEL
}

enum OrderLifecycleStatus {
  DRAFT
  PAYMENT_PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  ALLOTTED
  SETTLED
  FAILED
  CANCELLED
}

enum ExecutionChannel {
  BSE_STAR_MF
  RTA_MOCK
  INTERNAL_MOCK
}

enum HoldingStatus {
  ACTIVE
  CLOSED
}

enum PaymentAttemptStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

enum StatementArtifactType {
  ACCOUNT_STATEMENT
  TRANSACTION_REPORT
  CAPITAL_GAINS
  CAS
}

enum SupportTicketType {
  INVESTING
  KYC
  MANDATE
  ORDER
  SIP
  REPORTING
  COMPLAINT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
  CLOSED
}

enum ConsentArtifactType {
  TERMS
  PRIVACY
  FATCA
  CRS
  NOMINATION
  KYC
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  phone            String?          @unique
  role             UserRole         @default(INVESTOR)
  riskProfile      RiskProfile?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  portfolios       Portfolio[]
  transactions     Transaction[]
  sipPlans         SIPPlan[]
  kycDocuments     KYCDocument[]
  contactInquiries ContactInquiry[]
  accounts         Account[]
  sessions         Session[]
  investorProfile  InvestorProfile?
  supportTickets   SupportTicket[]
  auditEvents      AuditEvent[]

  @@index([role])
}

model Portfolio {
  id                String          @id @default(cuid())
  userId            String
  name              String
  description       String?
  goalAmount        Decimal?        @db.Decimal(18, 2)
  currentValue      Decimal         @default(0) @db.Decimal(18, 2)
  investedAmount    Decimal         @default(0) @db.Decimal(18, 2)
  expectedReturnPct Decimal?        @db.Decimal(5, 2)
  status            PortfolioStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  sipPlans          SIPPlan[]

  @@unique([userId, name])
  @@index([userId])
}

model Fund {
  id                String             @id @default(cuid())
  amcName           String
  schemeCode        String             @unique
  name              String
  category          String
  subCategory       String?
  nav               Decimal?           @db.Decimal(14, 4)
  riskLevel         String?
  expenseRatio      Decimal?           @db.Decimal(5, 2)
  minimumInvestment Decimal?           @db.Decimal(12, 2)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  transactions      Transaction[]
  sipPlans          SIPPlan[]
  folios            Folio[]
  orders            Order[]
  holdingLots       HoldingLot[]
  positionSnapshots PositionSnapshot[]

  @@index([amcName])
  @@index([category])
}

model SIPPlan {
  id                    String        @id @default(cuid())
  userId                String
  portfolioId           String
  fundId                String
  installmentAmount     Decimal       @db.Decimal(12, 2)
  frequency             SIPFrequency  @default(MONTHLY)
  startDate             DateTime
  endDate               DateTime?
  nextInstallmentDate   DateTime?
  totalInstallments     Int?
  completedInstallments Int           @default(0)
  status                SIPStatus     @default(ACTIVE)
  autoDebitMandateId    String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio             Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund                  Fund          @relation(fields: [fundId], references: [id], onDelete: Restrict)
  transactions          Transaction[]

  @@index([userId])
  @@index([portfolioId])
  @@index([fundId])
  @@index([status])
}

model Transaction {
  id             String            @id @default(cuid())
  userId         String
  portfolioId    String
  fundId         String
  sipPlanId      String?
  orderRef       String            @unique
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  units          Decimal           @db.Decimal(18, 6)
  navAtExecution Decimal           @db.Decimal(14, 4)
  amount         Decimal           @db.Decimal(12, 2)
  fees           Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal           @default(0) @db.Decimal(12, 2)
  executedAt     DateTime?
  settlementDate DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio      Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund           Fund              @relation(fields: [fundId], references: [id], onDelete: Restrict)
  sipPlan        SIPPlan?          @relation(fields: [sipPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([portfolioId])
  @@index([fundId])
  @@index([sipPlanId])
  @@index([status])
  @@index([type])
}

model KYCDocument {
  id              String          @id @default(cuid())
  userId          String
  type            KYCDocumentType
  documentNumber  String
  documentUrl     String
  issuedOn        DateTime?
  expiresOn       DateTime?
  status          KYCStatus       @default(PENDING)
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, documentNumber])
  @@index([userId])
  @@index([status])
}

model ContactInquiry {
  id         String               @id @default(cuid())
  userId     String?
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     ContactInquiryStatus @default(NEW)
  resolvedAt DateTime?
  assignedTo String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model InvestorProfile {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  dateOfBirth        DateTime?
  panMasked          String?
  kraReference       String?
  ckycReference      String?
  taxStatus          TaxStatus                @default(INDIVIDUAL)
  residencyStatus    InvestorResidencyStatus  @default(RESIDENT_INDIAN)
  occupation         String?
  annualIncomeBand   String?
  riskProfile        RiskProfile?
  onboardingStatus   InvestorOnboardingStatus @default(DRAFT)
  emailVerified      Boolean                  @default(false)
  mobileVerified     Boolean                  @default(false)
  fatcaAcceptedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycCase            KycCase?
  bankAccounts       BankAccount[]
  bankMandates       BankMandate[]
  nominations        Nomination[]
  folios             Folio[]
  orders             Order[]
  holdingLots        HoldingLot[]
  positionSnapshots  PositionSnapshot[]
  paymentAttempts    PaymentAttempt[]
  statementArtifacts StatementArtifact[]
  supportTickets     SupportTicket[]
  auditEvents        AuditEvent[]
  consentArtifacts   ConsentArtifact[]

  @@index([onboardingStatus])
}

model KycCase {
  id                String          @id @default(cuid())
  investorProfileId String          @unique
  status            KycCaseStatus   @default(NOT_STARTED)
  kraStatus         String?
  ipvStatus         String?
  remediationReason String?
  lastCheckedAt     DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  investorProfile   InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)

  @@index([status])
}

model BankAccount {
  id                  String            @id @default(cuid())
  investorProfileId   String
  bankName            String
  accountHolderName   String
  maskedAccountNumber String
  ifscCode            String
  accountType         String
  status              BankAccountStatus @default(PENDING)
  isDefault           Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  investorProfile     InvestorProfile   @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  bankMandates        BankMandate[]
  folios              Folio[]

  @@index([investorProfileId])
}

model BankMandate {
  id                String            @id @default(cuid())
  investorProfileId String
  bankAccountId     String
  provider          String
  rail              PaymentRail
  mandateReference  String            @unique
  status            BankMandateStatus @default(PENDING)
  maxAmount         Decimal?          @db.Decimal(12, 2)
  validTill         DateTime?
  authorizedAt      DateTime?
  pausedAt          DateTime?
  revokedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  investorProfile   InvestorProfile   @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  paymentAttempts   PaymentAttempt[]

  @@index([investorProfileId])
  @@index([bankAccountId])
  @@index([status])
}

model Nomination {
  id                String           @id @default(cuid())
  investorProfileId String
  nomineeName       String
  relationship      String
  allocationPct     Decimal          @default(100) @db.Decimal(5, 2)
  status            NominationStatus @default(PENDING)
  isMinor           Boolean          @default(false)
  guardianName      String?
  declaredAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  investorProfile   InvestorProfile  @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  folios            Folio[]

  @@index([investorProfileId])
}

model Folio {
  id                String             @id @default(cuid())
  investorProfileId String
  fundId            String?
  bankAccountId     String?
  nominationId      String?
  folioNumber       String
  amcName           String
  holderMode        HolderMode         @default(SINGLE)
  brokerCode        String?
  euin              String?
  rtaProvider       String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  investorProfile   InvestorProfile    @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  fund              Fund?              @relation(fields: [fundId], references: [id], onDelete: SetNull)
  bankAccount       BankAccount?       @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  nomination        Nomination?        @relation(fields: [nominationId], references: [id], onDelete: SetNull)
  orders            Order[]
  holdingLots       HoldingLot[]
  positionSnapshots PositionSnapshot[]

  @@unique([investorProfileId, folioNumber])
  @@index([investorProfileId])
}

model Order {
  id                 String                @id @default(cuid())
  investorProfileId  String
  folioId            String?
  fundId             String
  kind               OrderKind
  status             OrderLifecycleStatus  @default(DRAFT)
  executionChannel   ExecutionChannel      @default(INTERNAL_MOCK)
  amount             Decimal               @db.Decimal(12, 2)
  units              Decimal?              @db.Decimal(18, 6)
  navApplicable      Decimal?              @db.Decimal(14, 4)
  paymentRail        PaymentRail?
  partnerReference   String?               @unique
  idempotencyKey     String?               @unique
  cutOffApplicableAt DateTime?
  initiatedAt        DateTime              @default(now())
  submittedAt        DateTime?
  allottedAt         DateTime?
  settledAt          DateTime?
  rejectionCode      String?
  rejectionMessage   String?
  remarks            String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  investorProfile    InvestorProfile       @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  folio              Folio?                @relation(fields: [folioId], references: [id], onDelete: SetNull)
  fund               Fund                  @relation(fields: [fundId], references: [id], onDelete: Restrict)
  executionEvents    OrderExecutionEvent[]
  holdingLots        HoldingLot[]
  paymentAttempts    PaymentAttempt[]

  @@index([investorProfileId])
  @@index([folioId])
  @@index([fundId])
  @@index([status])
  @@index([kind])
}

model OrderExecutionEvent {
  id                String               @id @default(cuid())
  orderId           String
  status            OrderLifecycleStatus
  source            String
  requestId         String?
  payloadJson       Json?
  signatureVerified Boolean              @default(false)
  happenedAt        DateTime             @default(now())
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model HoldingLot {
  id                String          @id @default(cuid())
  investorProfileId String
  folioId           String
  fundId            String
  sourceOrderId     String?
  units             Decimal         @db.Decimal(18, 6)
  availableUnits    Decimal         @db.Decimal(18, 6)
  costAmount        Decimal         @db.Decimal(12, 2)
  currentValue      Decimal?        @db.Decimal(12, 2)
  unrealizedGain    Decimal?        @db.Decimal(12, 2)
  asOfDate          DateTime?
  status            HoldingStatus   @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  investorProfile   InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  folio             Folio           @relation(fields: [folioId], references: [id], onDelete: Cascade)
  fund              Fund            @relation(fields: [fundId], references: [id], onDelete: Restrict)
  sourceOrder       Order?          @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)

  @@index([investorProfileId])
  @@index([folioId])
  @@index([fundId])
}

model PositionSnapshot {
  id                String          @id @default(cuid())
  investorProfileId String
  folioId           String?
  fundId            String
  units             Decimal         @db.Decimal(18, 6)
  investedValue     Decimal         @db.Decimal(12, 2)
  currentValue      Decimal         @db.Decimal(12, 2)
  unrealizedGain    Decimal         @db.Decimal(12, 2)
  xirrPct           Decimal?        @db.Decimal(6, 2)
  asOfDate          DateTime
  createdAt         DateTime        @default(now())
  investorProfile   InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  folio             Folio?          @relation(fields: [folioId], references: [id], onDelete: SetNull)
  fund              Fund            @relation(fields: [fundId], references: [id], onDelete: Restrict)

  @@unique([investorProfileId, fundId, asOfDate])
  @@index([investorProfileId])
  @@index([fundId])
}

model PaymentAttempt {
  id                String               @id @default(cuid())
  investorProfileId String
  orderId           String?
  bankMandateId     String?
  rail              PaymentRail
  status            PaymentAttemptStatus @default(INITIATED)
  amount            Decimal              @db.Decimal(12, 2)
  providerReference String?              @unique
  paymentReference  String?
  failureReason     String?
  initiatedAt       DateTime             @default(now())
  completedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  investorProfile   InvestorProfile      @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  order             Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bankMandate       BankMandate?         @relation(fields: [bankMandateId], references: [id], onDelete: SetNull)

  @@index([investorProfileId])
  @@index([orderId])
  @@index([bankMandateId])
  @@index([status])
}

model StatementArtifact {
  id                String                @id @default(cuid())
  investorProfileId String
  type              StatementArtifactType
  label             String
  fileUrl           String?
  source            String?
  periodStart       DateTime?
  periodEnd         DateTime?
  generatedAt       DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  investorProfile   InvestorProfile       @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)

  @@index([investorProfileId])
  @@index([type])
}

model SupportTicket {
  id                String              @id @default(cuid())
  userId            String?
  investorProfileId String?
  type              SupportTicketType
  status            SupportTicketStatus @default(OPEN)
  subject           String
  description       String
  priority          String?
  scoresReference   String?
  responseDueAt     DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  investorProfile   InvestorProfile?    @relation(fields: [investorProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([investorProfileId])
  @@index([status])
}

model AuditEvent {
  id                String           @id @default(cuid())
  userId            String?
  investorProfileId String?
  entityType        String
  entityId          String?
  action            String
  metadata          Json?
  createdAt         DateTime         @default(now())
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  investorProfile   InvestorProfile? @relation(fields: [investorProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([investorProfileId])
  @@index([createdAt])
}

model ConsentArtifact {
  id                String              @id @default(cuid())
  investorProfileId String
  type              ConsentArtifactType
  version           String
  ipAddress         String?
  userAgent         String?
  acceptedAt        DateTime            @default(now())
  investorProfile   InvestorProfile     @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)

  @@unique([investorProfileId, type, version])
  @@index([investorProfileId])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
