generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  INVESTOR
  ADVISOR
  ADMIN
}

enum RiskProfile {
  LOW
  MODERATE
  HIGH
}

enum PortfolioStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum TransactionType {
  BUY
  SELL
  SWITCH
  REDEEM
  STP
  SWP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SIPFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SIPStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum KYCDocumentType {
  PAN
  AADHAAR
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  OTHER
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum ContactInquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  phone            String?          @unique
  role             UserRole         @default(INVESTOR)
  riskProfile      RiskProfile?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  portfolios       Portfolio[]
  transactions     Transaction[]
  sipPlans         SIPPlan[]
  kycDocuments     KYCDocument[]
  contactInquiries ContactInquiry[]
  accounts         Account[]
  sessions         Session[]

  @@index([role])
}

model Portfolio {
  id                String          @id @default(cuid())
  userId            String
  name              String
  description       String?
  goalAmount        Decimal?        @db.Decimal(18, 2)
  currentValue      Decimal         @default(0) @db.Decimal(18, 2)
  investedAmount    Decimal         @default(0) @db.Decimal(18, 2)
  expectedReturnPct Decimal?        @db.Decimal(5, 2)
  status            PortfolioStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  sipPlans          SIPPlan[]

  @@index([userId])
  @@unique([userId, name])
}

model Fund {
  id                String        @id @default(cuid())
  amcName           String
  schemeCode        String        @unique
  name              String
  category          String
  subCategory       String?
  nav               Decimal?      @db.Decimal(14, 4)
  riskLevel         String?
  expenseRatio      Decimal?      @db.Decimal(5, 2)
  minimumInvestment Decimal?      @db.Decimal(12, 2)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  transactions      Transaction[]
  sipPlans          SIPPlan[]

  @@index([amcName])
  @@index([category])
}

model SIPPlan {
  id                    String       @id @default(cuid())
  userId                String
  portfolioId           String
  fundId                String
  installmentAmount     Decimal      @db.Decimal(12, 2)
  frequency             SIPFrequency @default(MONTHLY)
  startDate             DateTime
  endDate               DateTime?
  nextInstallmentDate   DateTime?
  totalInstallments     Int?
  completedInstallments Int          @default(0)
  status                SIPStatus    @default(ACTIVE)
  autoDebitMandateId    String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio             Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund                  Fund         @relation(fields: [fundId], references: [id], onDelete: Restrict)
  transactions          Transaction[]

  @@index([userId])
  @@index([portfolioId])
  @@index([fundId])
  @@index([status])
}

model Transaction {
  id             String            @id @default(cuid())
  userId         String
  portfolioId    String
  fundId         String
  sipPlanId      String?
  orderRef       String            @unique
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  units          Decimal           @db.Decimal(18, 6)
  navAtExecution Decimal           @db.Decimal(14, 4)
  amount         Decimal           @db.Decimal(12, 2)
  fees           Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal           @default(0) @db.Decimal(12, 2)
  executedAt     DateTime?
  settlementDate DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio      Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund           Fund              @relation(fields: [fundId], references: [id], onDelete: Restrict)
  sipPlan        SIPPlan?          @relation(fields: [sipPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([portfolioId])
  @@index([fundId])
  @@index([sipPlanId])
  @@index([status])
  @@index([type])
}

model KYCDocument {
  id              String          @id @default(cuid())
  userId          String
  type            KYCDocumentType
  documentNumber  String
  documentUrl     String
  issuedOn        DateTime?
  expiresOn       DateTime?
  status          KYCStatus       @default(PENDING)
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@unique([userId, type, documentNumber])
}

model ContactInquiry {
  id         String               @id @default(cuid())
  userId     String?
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     ContactInquiryStatus @default(NEW)
  resolvedAt DateTime?
  assignedTo String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
